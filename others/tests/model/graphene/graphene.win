##
## Optical conductivity
##
berry = true
berry_task = kubo
berry_kmesh = 200 200 1
iprint=2
kubo_freq_max = 50
kubo_smr_type = gauss
#adpt_smr = false
smr_fixed_en_width = 0.05 ! koretsune-san's calc.

